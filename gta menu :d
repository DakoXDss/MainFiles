-- WINDOW
-- ══════════════════════════════════════
function ModMenu.new(title, subtitle)
    local self = setmetatable({}, ModMenu)
    self._tabs = {}
    self._activeTab = nil
    self._open = true
    self._toggleKey = Enum.KeyCode.RightShift

    -- ScreenGui
    self.ScreenGui = create("ScreenGui", {
        Name = "GTAModMenu",
        ResetOnSpawn = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        Parent = player:WaitForChild("PlayerGui"),
    })

    -- Main Frame
    self.Main = create("Frame", {
        Name = "Main",
        Size = UDim2.new(0, 520, 0, 380),
        Position = UDim2.new(0.5, -260, 0.5, -190),
        BackgroundColor3 = Theme.Background,
        BorderSizePixel = 0,
        Parent = self.ScreenGui,
    })
    addCorner(self.Main, 6)
    addStroke(self.Main, Theme.HeaderAccent, 1)

    -- Drop shadow
    local shadow = create("ImageLabel", {
        Name = "Shadow",
        Size = UDim2.new(1, 30, 1, 30),
        Position = UDim2.new(0, -15, 0, -15),
        BackgroundTransparency = 1,
        Image = "rbxassetid://6015897843",
        ImageColor3 = Theme.Shadow,
        ImageTransparency = 0.4,
        ScaleType = Enum.ScaleType.Slice,
        SliceCenter = Rect.new(49, 49, 450, 450),
        ZIndex = -1,
        Parent = self.Main,
    })

    -- Header bar
    local header = create("Frame", {
        Name = "Header",
        Size = UDim2.new(1, 0, 0, 52),
        BackgroundColor3 = Theme.Header,
        BorderSizePixel = 0,
        Parent = self.Main,
    })
    addCorner(header, 6)
    -- clip bottom corners
    create("Frame", {
        Size = UDim2.new(1, 0, 0, 12),
        Position = UDim2.new(0, 0, 1, -12),
        BackgroundColor3 = Theme.Header,
        BorderSizePixel = 0,
        Parent = header,
    })

    -- Accent stripe
    create("Frame", {
        Size = UDim2.new(1, 0, 0, 2),
        Position = UDim2.new(0, 0, 1, 0),
        BackgroundColor3 = Theme.HeaderAccent,
        BorderSizePixel = 0,
        Parent = header,
    })

    -- Title
    create("TextLabel", {
        Size = UDim2.new(1, -20, 0, 28),
        Position = UDim2.new(0, 14, 0, 4),
        BackgroundTransparency = 1,
        Text = string.upper(title or "MOD MENU"),
        TextColor3 = Theme.TextPrimary,
        Font = Theme.Font,
        TextSize = 18,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = header,
    })

    -- Subtitle
    create("TextLabel", {
        Size = UDim2.new(1, -20, 0, 16),
        Position = UDim2.new(0, 14, 0, 30),
        BackgroundTransparency = 1,
        Text = subtitle or "v1.0 — press RShift to toggle",
        TextColor3 = Theme.TextSecondary,
        Font = Theme.FontBody,
        TextSize = 11,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = header,
    })

    -- Tab sidebar
    self.TabContainer = create("ScrollingFrame", {
        Name = "Tabs",
        Size = UDim2.new(0, 130, 1, -56),
        Position = UDim2.new(0, 0, 0, 56),
        BackgroundColor3 = Theme.OptionBg,
        BorderSizePixel = 0,
        ScrollBarThickness = 0,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        Parent = self.Main,
    })
    create("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 2),
        Parent = self.TabContainer,
    })
    create("UIPadding", { PaddingTop = UDim.new(0, 4), PaddingBottom = UDim.new(0, 4), Parent = self.TabContainer })

    -- Content area
    self.ContentArea = create("Frame", {
        Name = "Content",
        Size = UDim2.new(1, -134, 1, -56),
        Position = UDim2.new(0, 134, 0, 56),
        BackgroundColor3 = Theme.Background,
        BorderSizePixel = 0,
        ClipsDescendants = true,
        Parent = self.Main,
    })

    -- Dragging
    self:_enableDrag(header)

    -- Toggle visibility
    UserInputService.InputBegan:Connect(function(input, gpe)
        if gpe then return end
        if input.KeyCode == self._toggleKey then
            self._open = not self._open
            self.Main.Visible = self._open
        end
    end)

    return self
end

function ModMenu:_enableDrag(handle)
    local dragging, dragStart, startPos
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = self.Main.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            self.Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

