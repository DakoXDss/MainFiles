                TextSize = 13,
                Size = UDim2.new(1, 0, 0, 15),
                BackgroundTransparency = 1,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = slider
            })

            local valLabel = create("TextLabel", {
                Text = tostring(value)..(sData.Suffix or ""),
                TextColor3 = theme.TextDim,
                FontFace = theme.Font,
                TextSize = 12,
                Position = UDim2.new(1, 0, 0, 0),
                AnchorPoint = Vector2.new(1, 0),
                Size = UDim2.new(0, 0, 0, 15),
                AutomaticSize = Enum.AutomaticSize.X,
                BackgroundTransparency = 1,
                TextXAlignment = Enum.TextXAlignment.Right,
                Parent = slider
            })

            local track = create("TextButton", {
                Name = "Track",
                BackgroundColor3 = theme.Surface,
                Position = UDim2.new(0, 0, 1, -12),
                Size = UDim2.new(1, 0, 0, 8),
                Text = "",
                AutoButtonColor = false,
                Parent = slider
            })
            addCorner(track, 2)
            addStroke(track, theme.Outline, 1)

            local fill = create("Frame", {
                Name = "Fill",
                BackgroundColor3 = theme.Accent,
                Size = UDim2.fromScale(0, 1),
                BorderSizePixel = 0,
                Parent = track
            })
            addCorner(fill, 2)

            local function update(input)
                local pos = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
                value = math.floor(min + (max - min) * pos)
                if sData.Increment then
                    value = math.floor(value / sData.Increment) * sData.Increment
                end
                
                fill.Size = UDim2.fromScale((value - min) / (max - min), 1)
                valLabel.Text = tostring(value)..(sData.Suffix or "")
                
                if sData.Flag then sectionAPI.Main.flags[sData.Flag] = value end
                sData.Callback(value)
            end

            local sliding = false
            track.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    sliding = true
                    update(input)
                end
            end)
            UserInputService.InputChanged:Connect(function(input)
                if sliding and input.UserInputType == Enum.UserInputType.MouseMovement then
                    update(input)
                end
            end)
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    sliding = false
                end
            end)

            -- Initial Set
            fill.Size = UDim2.fromScale((value - min) / (max - min), 1)
            return slider
        end

        -- DROPDOWN
        function sectionAPI:addDropdown(dData)
            local options = dData.Options or {}
            local selected = dData.Default or options[1]
            local open = false

            local dropdown = create("Frame", {
                Name = dData.Name.."_Dropdown",
                BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 0, 45),
                Parent = container
            })
            
            local label = create("TextLabel", {
                Text = dData.Name,
                TextColor3 = theme.TextDim,
                FontFace = theme.Font,
                TextSize = 13,
                Size = UDim2.new(1, 0, 0, 15),
                BackgroundTransparency = 1,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = dropdown
            })

            local button = create("TextButton", {
                Name = "Button",
                BackgroundColor3 = theme.Surface,
                Position = UDim2.new(0, 0, 1, -22),
                Size = UDim2.new(1, 0, 0, 22),
                Text = "",
                AutoButtonColor = false,
                Parent = dropdown
            })
            addCorner(button, 4)
            addStroke(button, theme.Outline, 1)

            local selLabel = create("TextLabel", {
                Text = (typeof(selected) == "table" and selected.Name or tostring(selected)),
                TextColor3 = theme.TextDim,
                FontFace = theme.Font,
                TextSize = 12,
                Position = UDim2.new(0, 8, 0, 0),
                Size = UDim2.new(1, -30, 1, 0),
                BackgroundTransparency = 1,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = button
            })

            local arrow = create("ImageLabel", {
                BackgroundTransparency = 1,
                Position = UDim2.new(1, -20, 0.5, 0),
                AnchorPoint = Vector2.new(0, 0.5),
                Size = UDim2.fromOffset(14, 14),
                Image = Aetherial.Icons.ChevronDown,
                ImageColor3 = theme.TextDim,
                Parent = button
            })

            local list = create("ScrollingFrame", {
                Name = "List",
                BackgroundColor3 = theme.Surface,
                Position = UDim2.new(0, 0, 1, 4),
                Size = UDim2.new(1, 0, 0, 100),
                ZIndex = 50,
                Visible = false,
                ScrollBarThickness = 2,
                ScrollBarImageColor3 = theme.Accent,
                Parent = button
            })
            addCorner(list, 4)
            addStroke(list, theme.Outline, 1)
            addListLayout(list, 2)
            addPadding(list, 4, 4, 4, 4)

            local function refresh()
                for _, child in pairs(list:GetChildren()) do
                    if child:IsA("TextButton") then child:Destroy() end
                end
                
                for _, opt in pairs(options) do
                    local optName = typeof(opt) == "table" and opt.Name or opt
                    local optBtn = create("TextButton", {
                        Text = optName,
                        TextColor3 = theme.TextDim,
                        FontFace = theme.Font,
                        TextSize = 12,
                        Size = UDim2.new(1, 0, 0, 22),
                        BackgroundColor3 = theme.SurfaceLight,
                        AutoButtonColor = false,
                        ZIndex = 51,
                        Parent = list
                    })
                    addCorner(optBtn, 3)

                    optBtn.MouseButton1Click:Connect(function()
                        selected = opt
                        selLabel.Text = optName
                        open = false
                        list.Visible = false
                        dData.Callback(opt)
                    end)
                end
            end

            button.MouseButton1Click:Connect(function()
                open = not open
                list.Visible = open
            end)

            refresh()
            return dropdown
        end

        -- KEYBIND
        function sectionAPI:addKeybind(kData)
            local theme = Aetherial.Themes.Holia
            local listening = false
            local bind = kData.Default or Enum.KeyCode.Unknown
            
            local keybind = create("Frame", {
                Name = kData.Name.."_Keybind",
                BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 0, 20),
                Parent = container
            })

            local label = create("TextLabel", {
                Text = kData.Name,
                TextColor3 = theme.TextDim,
                FontFace = theme.Font,
                TextSize = 13,
                BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 1, 0),
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = keybind
            })

            local button = create("TextButton", {
                BackgroundColor3 = theme.Surface,
                Size = UDim2.new(0, 60, 0, 18),
                Position = UDim2.new(1, 0, 0.5, 0),
                AnchorPoint = Vector2.new(1, 0.5),
                Text = tostring(bind):gsub("Enum.KeyCode.", ""),
                TextColor3 = theme.Accent,
                FontFace = theme.Font,
                TextSize = 11,
                AutoButtonColor = false,
                Parent = keybind
            })
            addCorner(button, 3)
            addStroke(button, theme.Outline, 1)

            button.MouseButton1Click:Connect(function()
                listening = true
                button.Text = "..."
            end)

            UserInputService.InputBegan:Connect(function(input)
                if listening then
                    if input.UserInputType == Enum.UserInputType.Keyboard then
                        bind = input.KeyCode
                        listening = false
                    elseif input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.MouseButton2 then
                        bind = input.UserInputType
                        listening = false
                    end
                    button.Text = tostring(bind):gsub("Enum.KeyCode.", ""):gsub("Enum.UserInputType.", "")
                    if kData.Callback then kData.Callback(bind) end
                else
                    if input.KeyCode == bind or input.UserInputType == bind then
                        if kData.OnActivate then kData.OnActivate() end
                    end
                end
            end)

            return keybind
        end

        return sectionAPI
    end

    return tabAPI
end

return Aetherial
