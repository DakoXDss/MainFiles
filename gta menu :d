local ModMenu = {}
ModMenu.__index = ModMenu

local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")
local player = Players.LocalPlayer

-- ── THEME ──
local Theme = {
    Background     = Color3.fromRGB(12, 12, 12),
    Header         = Color3.fromRGB(0, 0, 0),
    HeaderAccent   = Color3.fromRGB(93, 138, 168),
    TabActive      = Color3.fromRGB(93, 138, 168),
    TabInactive    = Color3.fromRGB(30, 30, 30),
    TabHover       = Color3.fromRGB(50, 50, 50),
    OptionBg       = Color3.fromRGB(18, 18, 18),
    OptionHover    = Color3.fromRGB(35, 35, 42),
    OptionSelected = Color3.fromRGB(93, 138, 168),
    TextPrimary    = Color3.fromRGB(235, 235, 235),
    TextSecondary  = Color3.fromRGB(160, 160, 160),
    ToggleOn       = Color3.fromRGB(93, 138, 168),
    ToggleOff      = Color3.fromRGB(60, 60, 60),
    SliderFill     = Color3.fromRGB(93, 138, 168),
    SliderTrack    = Color3.fromRGB(40, 40, 40),
    Divider        = Color3.fromRGB(40, 40, 40),
    Shadow         = Color3.fromRGB(0, 0, 0),
    Font           = Enum.Font.GothamBold,
    FontBody       = Enum.Font.GothamMedium,
}

-- ── UTILITY ──
local function create(class, props)
    local inst = Instance.new(class)
    for k, v in pairs(props) do
        if k ~= "Parent" then inst[k] = v end
    end
    if props.Parent then inst.Parent = props.Parent end
    return inst
end

local function tweenProp(obj, props, duration)
    TweenService:Create(obj, TweenInfo.new(duration or 0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props):Play()
end

local function addCorner(parent, radius)
    create("UICorner", { CornerRadius = UDim.new(0, radius or 4), Parent = parent })
end

local function addStroke(parent, color, thickness)
    create("UIStroke", { Color = color or Theme.Divider, Thickness = thickness or 1, Parent = parent })
end

