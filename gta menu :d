-- TAB
-- ══════════════════════════════════════
function ModMenu:AddTab(name, icon)
    local tab = { Name = name, _elements = {} }

    -- Tab button
    tab.Button = create("TextButton", {
        Size = UDim2.new(1, -8, 0, 32),
        BackgroundColor3 = Theme.TabInactive,
        BorderSizePixel = 0,
        Text = "",
        AutoButtonColor = false,
        Parent = self.TabContainer,
    })
    addCorner(tab.Button, 4)

    local iconLabel
    if icon then
        iconLabel = create("TextLabel", {
            Size = UDim2.new(0, 22, 1, 0),
            Position = UDim2.new(0, 8, 0, 0),
            BackgroundTransparency = 1,
            Text = icon,
            TextColor3 = Theme.TextSecondary,
            Font = Theme.Font,
            TextSize = 14,
            Parent = tab.Button,
        })
    end

    tab.Label = create("TextLabel", {
        Size = UDim2.new(1, icon and -38 or -16, 1, 0),
        Position = UDim2.new(0, icon and 34 or 10, 0, 0),
        BackgroundTransparency = 1,
        Text = name,
        TextColor3 = Theme.TextSecondary,
        Font = Theme.FontBody,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = tab.Button,
    })

    -- Content page
    tab.Page = create("ScrollingFrame", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ScrollBarThickness = 3,
        ScrollBarImageColor3 = Theme.HeaderAccent,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        Visible = false,
        Parent = self.ContentArea,
    })
    create("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 3),
        Parent = tab.Page,
    })
    create("UIPadding", {
        PaddingLeft = UDim.new(0, 8),
        PaddingRight = UDim.new(0, 8),
        PaddingTop = UDim.new(0, 6),
        PaddingBottom = UDim.new(0, 6),
        Parent = tab.Page,
    })

    -- Hover
    tab.Button.MouseEnter:Connect(function()
        if self._activeTab ~= tab then
            tweenProp(tab.Button, { BackgroundColor3 = Theme.TabHover })
        end
    end)
    tab.Button.MouseLeave:Connect(function()
        if self._activeTab ~= tab then
            tweenProp(tab.Button, { BackgroundColor3 = Theme.TabInactive })
        end
    end)

    -- Click
    tab.Button.MouseButton1Click:Connect(function()
        self:_selectTab(tab)
    end)

    table.insert(self._tabs, tab)

    -- Auto-select first
    if #self._tabs == 1 then
        self:_selectTab(tab)
    end

    -- Return a tab builder
    local builder = {}

    function builder:AddToggle(text, default, callback)
        local state = default or false
        callback = callback or function() end

        local row = create("Frame", {
            Size = UDim2.new(1, 0, 0, 34),
            BackgroundColor3 = Theme.OptionBg,
            BorderSizePixel = 0,
            Parent = tab.Page,
        })
        addCorner(row, 4)

        create("TextLabel", {
            Size = UDim2.new(1, -60, 1, 0),
            Position = UDim2.new(0, 12, 0, 0),
            BackgroundTransparency = 1,
            Text = text,
            TextColor3 = Theme.TextPrimary,
            Font = Theme.FontBody,
            TextSize = 13,
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = row,
        })

        local toggleBg = create("Frame", {
            Size = UDim2.new(0, 36, 0, 18),
            Position = UDim2.new(1, -48, 0.5, -9),
            BackgroundColor3 = state and Theme.ToggleOn or Theme.ToggleOff,
            BorderSizePixel = 0,
            Parent = row,
        })
        addCorner(toggleBg, 9)

        local knob = create("Frame", {
            Size = UDim2.new(0, 14, 0, 14),
            Position = state and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7),
            BackgroundColor3 = Theme.TextPrimary,
            BorderSizePixel = 0,
            Parent = toggleBg,
        })
        addCorner(knob, 7)

        local btn = create("TextButton", {
            Size = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            Text = "",
            Parent = row,
        })

        -- hover
        btn.MouseEnter:Connect(function() tweenProp(row, { BackgroundColor3 = Theme.OptionHover }) end)
        btn.MouseLeave:Connect(function() tweenProp(row, { BackgroundColor3 = Theme.OptionBg }) end)

        btn.MouseButton1Click:Connect(function()
            state = not state
            tweenProp(toggleBg, { BackgroundColor3 = state and Theme.ToggleOn or Theme.ToggleOff })
            tweenProp(knob, { Position = state and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7) })
            callback(state)
        end)

        return { SetValue = function(_, v) state = v; callback(v) end }
    end

    function builder:AddSlider(text, min, max, default, callback)
        callback = callback or function() end
        min = min or 0
        max = max or 100
        local value = math.clamp(default or min, min, max)

        local row = create("Frame", {
            Size = UDim2.new(1, 0, 0, 50),
            BackgroundColor3 = Theme.OptionBg,
            BorderSizePixel = 0,
            Parent = tab.Page,
        })
        addCorner(row, 4)

        local label = create("TextLabel", {
            Size = UDim2.new(1, -60, 0, 20),
            Position = UDim2.new(0, 12, 0, 4),
            BackgroundTransparency = 1,
            Text = text,
            TextColor3 = Theme.TextPrimary,
            Font = Theme.FontBody,
            TextSize = 13,
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = row,
        })

        local valLabel = create("TextLabel", {
            Size = UDim2.new(0, 44, 0, 20),
            Position = UDim2.new(1, -52, 0, 4),
            BackgroundTransparency = 1,
            Text = tostring(math.floor(value)),
            TextColor3 = Theme.HeaderAccent,
            Font = Theme.Font,
            TextSize = 13,
            TextXAlignment = Enum.TextXAlignment.Right,
            Parent = row,
        })

        local track = create("Frame", {
            Size = UDim2.new(1, -24, 0, 6),
            Position = UDim2.new(0, 12, 0, 32),
            BackgroundColor3 = Theme.SliderTrack,
            BorderSizePixel = 0,
            Parent = row,
        })
        addCorner(track, 3)

        local fill = create("Frame", {
            Size = UDim2.new((value - min) / (max - min), 0, 1, 0),
            BackgroundColor3 = Theme.SliderFill,
            BorderSizePixel = 0,
            Parent = track,
        })
        addCorner(fill, 3)

        local clickArea = create("TextButton", {
            Size = UDim2.new(1, 0, 0, 22),
            Position = UDim2.new(0, 0, 0, 26),
            BackgroundTransparency = 1,
            Text = "",
            Parent = row,
        })

        -- hover on row
        local hovered = false
        row.MouseEnter:Connect(function() hovered = true; tweenProp(row, { BackgroundColor3 = Theme.OptionHover }) end)
        row.MouseLeave:Connect(function() hovered = false; tweenProp(row, { BackgroundColor3 = Theme.OptionBg }) end)

        local sliding = false
        local function updateSlider(inputX)
            local trackAbs = track.AbsolutePosition.X
            local trackWidth = track.AbsoluteSize.X
            local pct = math.clamp((inputX - trackAbs) / trackWidth, 0, 1)
            value = math.floor(min + pct * (max - min))
            fill.Size = UDim2.new(pct, 0, 1, 0)
            valLabel.Text = tostring(value)
            callback(value)
        end

        clickArea.MouseButton1Down:Connect(function()
            sliding = true
            updateSlider(UserInputService:GetMouseLocation().X)
        end)
        UserInputService.InputChanged:Connect(function(input)
            if sliding and input.UserInputType == Enum.UserInputType.MouseMovement then
                updateSlider(input.Position.X)
            end
        end)
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then sliding = false end
        end)

        return { SetValue = function(_, v) value = v; callback(v) end }
    end

    function builder:AddButton(text, callback)
        callback = callback or function() end

        local btn = create("TextButton", {
            Size = UDim2.new(1, 0, 0, 34),
            BackgroundColor3 = Theme.OptionBg,
            BorderSizePixel = 0,
            Text = "",
            AutoButtonColor = false,
            Parent = tab.Page,
        })
        addCorner(btn, 4)

        create("TextLabel", {
            Size = UDim2.new(1, -24, 1, 0),
            Position = UDim2.new(0, 12, 0, 0),
            BackgroundTransparency = 1,
            Text = text,
            TextColor3 = Theme.TextPrimary,
            Font = Theme.FontBody,
            TextSize = 13,
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = btn,
        })

        -- arrow hint
        create("TextLabel", {
            Size = UDim2.new(0, 20, 1, 0),
            Position = UDim2.new(1, -28, 0, 0),
            BackgroundTransparency = 1,
            Text = "›",
            TextColor3 = Theme.TextSecondary,
            Font = Theme.Font,
            TextSize = 18,
            Parent = btn,
        })

        btn.MouseEnter:Connect(function() tweenProp(btn, { BackgroundColor3 = Theme.OptionHover }) end)
        btn.MouseLeave:Connect(function() tweenProp(btn, { BackgroundColor3 = Theme.OptionBg }) end)
        btn.MouseButton1Click:Connect(callback)
    end

    function builder:AddLabel(text)
        local lbl = create("TextLabel", {
            Size = UDim2.new(1, 0, 0, 22),
            BackgroundTransparency = 1,
            Text = string.upper(text),
            TextColor3 = Theme.TextSecondary,
            Font = Theme.Font,
            TextSize = 10,
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = tab.Page,
        })
        create("UIPadding", { PaddingLeft = UDim.new(0, 4), Parent = lbl })
    end

    function builder:AddDivider()
        local div = create("Frame", {
            Size = UDim2.new(1, 0, 0, 1),
            BackgroundColor3 = Theme.Divider,
            BorderSizePixel = 0,
            Parent = tab.Page,
        })
    end

    function builder:AddDropdown(text, options, default, callback)
        callback = callback or function() end
        options = options or {}
        local selected = default or options[1] or ""
        local expanded = false

        local container = create("Frame", {
            Size = UDim2.new(1, 0, 0, 34),
            BackgroundColor3 = Theme.OptionBg,
            BorderSizePixel = 0,
            ClipsDescendants = true,
            Parent = tab.Page,
        })
        addCorner(container, 4)

        create("TextLabel", {
            Size = UDim2.new(0.5, -8, 0, 34),
            Position = UDim2.new(0, 12, 0, 0),
            BackgroundTransparency = 1,
            Text = text,
            TextColor3 = Theme.TextPrimary,
            Font = Theme.FontBody,
            TextSize = 13,
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = container,
        })

        local selLabel = create("TextLabel", {
            Size = UDim2.new(0.5, -28, 0, 34),
            Position = UDim2.new(0.5, 0, 0, 0),
            BackgroundTransparency = 1,
            Text = selected,
            TextColor3 = Theme.HeaderAccent,
            Font = Theme.FontBody,
            TextSize = 13,
            TextXAlignment = Enum.TextXAlignment.Right,
            Parent = container,
        })

        local arrow = create("TextLabel", {
            Size = UDim2.new(0, 16, 0, 34),
            Position = UDim2.new(1, -22, 0, 0),
            BackgroundTransparency = 1,
            Text = "▾",
            TextColor3 = Theme.TextSecondary,
            Font = Theme.Font,
            TextSize = 12,
            Parent = container,
        })

        local optionFrames = {}
        for i, opt in ipairs(options) do
            local optBtn = create("TextButton", {
                Size = UDim2.new(1, -8, 0, 28),
                Position = UDim2.new(0, 4, 0, 34 + (i - 1) * 30),
                BackgroundColor3 = Theme.Background,
                BorderSizePixel = 0,
                Text = opt,
                TextColor3 = Theme.TextPrimary,
                Font = Theme.FontBody,
                TextSize = 12,
                AutoButtonColor = false,
                Parent = container,
            })
            addCorner(optBtn, 3)
            optBtn.MouseEnter:Connect(function() tweenProp(optBtn, { BackgroundColor3 = Theme.OptionHover }) end)
            optBtn.MouseLeave:Connect(function() tweenProp(optBtn, { BackgroundColor3 = Theme.Background }) end)
            optBtn.MouseButton1Click:Connect(function()
                selected = opt
                selLabel.Text = opt
                expanded = false
                tweenProp(container, { Size = UDim2.new(1, 0, 0, 34) }, 0.2)
                arrow.Text = "▾"
                callback(opt)
            end)
            table.insert(optionFrames, optBtn)
        end

        local headerBtn = create("TextButton", {
            Size = UDim2.new(1, 0, 0, 34),
            BackgroundTransparency = 1,
            Text = "",
            Parent = container,
        })
        headerBtn.MouseButton1Click:Connect(function()
            expanded = not expanded
            local totalH = expanded and (34 + #options * 30 + 4) or 34
            tweenProp(container, { Size = UDim2.new(1, 0, 0, totalH) }, 0.2)
            arrow.Text = expanded and "▴" or "▾"
        end)
    end

    return builder
end

function ModMenu:_selectTab(tab)
    if self._activeTab then
        self._activeTab.Page.Visible = false
        tweenProp(self._activeTab.Button, { BackgroundColor3 = Theme.TabInactive })
        self._activeTab.Label.TextColor3 = Theme.TextSecondary
    end
    self._activeTab = tab
    tab.Page.Visible = true
    tweenProp(tab.Button, { BackgroundColor3 = Theme.TabActive })
    tab.Label.TextColor3 = Theme.TextPrimary
end

function ModMenu:SetToggleKey(keycode)
    self._toggleKey = keycode
end

function ModMenu:Destroy()
    self.ScreenGui:Destroy()
end

return ModMenu
