        -- ════════════════════════════════════════════════════════════════

        -- TOGGLE (Checkbox)
        function sectionAPI:addToggle(tData)
            local state = tData.Default or false
            local toggle = create("TextButton", {
                Name = tData.Name.."_Toggle",
                BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 0, 20),
                Text = "",
                AutoButtonColor = false,
                Parent = container
            })

            local box = create("Frame", {
                Name = "Box",
                BackgroundColor3 = theme.Surface,
                Size = UDim2.fromOffset(16, 16),
                Position = UDim2.new(0, 0, 0.5, 0),
                AnchorPoint = Vector2.new(0, 0.5),
                Parent = toggle
            })
            addCorner(box, 3)
            addStroke(box, theme.Outline, 1)

            local check = create("ImageLabel", {
                Name = "Check",
                BackgroundTransparency = 1,
                Size = UDim2.fromScale(0.7, 0.7),
                Position = UDim2.fromScale(0.5, 0.5),
                AnchorPoint = Vector2.new(0.5, 0.5),
                Image = "rbxassetid://10723326164",
                ImageColor3 = Color3.fromRGB(0,0,0),
                ImageTransparency = 1,
                Parent = box
            })

            local label = create("TextLabel", {
                Text = tData.Name,
                TextColor3 = theme.TextDim,
                FontFace = theme.Font,
                TextSize = 13,
                BackgroundTransparency = 1,
                Position = UDim2.new(0, 24, 0, 0),
                Size = UDim2.new(1, -24, 1, 0),
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = toggle
            })

            local function update()
                if state then
                    tween(box, {BackgroundColor3 = theme.Accent}, 0.2)
                    tween(check, {ImageTransparency = 0}, 0.2)
                    tween(label, {TextColor3 = theme.Text}, 0.2)
                else
                    tween(box, {BackgroundColor3 = theme.Surface}, 0.2)
                    tween(check, {ImageTransparency = 1}, 0.2)
                    tween(label, {TextColor3 = theme.TextDim}, 0.2)
                end
                if tData.Flag then sectionAPI.Main.flags[tData.Flag] = state end
                tData.Callback(state)
            end

            toggle.MouseButton1Click:Connect(function()
                state = not state
                update()
            end)

            update()
            return toggle
        end

        -- SLIDER
        function sectionAPI:addSlider(sData)
            local min = sData.Min or 0
            local max = sData.Max or 100
            local value = sData.Default or min
            
            local slider = create("Frame", {
                Name = sData.Name.."_Slider",
                BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 0, 35),
                Parent = container
            })

            local label = create("TextLabel", {
