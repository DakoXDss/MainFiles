    })

    local label = create("TextLabel", {
        Text = data.Name,
        TextColor3 = theme.TextDim,
        FontFace = theme.Font,
        TextSize = 13,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 35, 0, 0),
        Size = UDim2.new(1, -35, 1, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = tabButton
    })

    -- Tab Page
    local tabPage = create("ScrollingFrame", {
        Name = data.Name.."_Page",
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 1, 0),
        ScrollBarThickness = 0,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        Visible = false,
        Parent = self.content
    })
    addPadding(tabPage, 15, 15, 15, 15)
    
    local leftCol = create("Frame", {
        Name = "Left",
        BackgroundTransparency = 1,
        Size = UDim2.new(0.5, -7, 1, 0),
        Parent = tabPage
    })
    addListLayout(leftCol, 15)
    
    local rightCol = create("Frame", {
        Name = "Right",
        BackgroundTransparency = 1,
        Position = UDim2.new(0.5, 7, 0, 0),
        Size = UDim2.new(0.5, -7, 1, 0),
        Parent = tabPage
    })
    addListLayout(rightCol, 15)

    -- API for Tab
    local tabAPI = {
        Main = self,
        Page = tabPage,
        Left = leftCol,
        Right = rightCol,
    }

    function tabAPI:select()
        for _, t in pairs(self.Main.tabs) do
            t.Page.Visible = false
            tween(t.Button, {BackgroundTransparency = 1}, 0.2)
            tween(t.Label, {TextColor3 = theme.TextDim}, 0.2)
            tween(t.Icon, {ImageColor3 = theme.TextDim}, 0.2)
            tween(t.Bar, {BackgroundTransparency = 1}, 0.2)
        end
        tabPage.Visible = true
        tween(tabButton, {BackgroundTransparency = 0.9, BackgroundColor3 = theme.Accent}, 0.2)
        tween(label, {TextColor3 = theme.Text}, 0.2)
        tween(icon, {ImageColor3 = theme.Accent}, 0.2)
        tween(activeBar, {BackgroundTransparency = 0}, 0.2)
    end

    tabButton.MouseButton1Click:Connect(function()
        tabAPI:select()
    end)

    table.insert(self.tabs, {Button = tabButton, Page = tabPage, Label = label, Icon = icon, Bar = activeBar})
    if #self.tabs == 1 then tabAPI:select() end

    -- ════════════════════════════════════════════════════════════════
