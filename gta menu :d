    })

    create("TextLabel", {
        Text = data.Message or "",
        TextColor3 = Aetherial.Themes.Holia.TextDim,
        FontFace = Aetherial.Themes.Holia.Font,
        TextSize = 12,
        TextWrapped = true,
        BackgroundTransparency = 1,
